# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
# Greagent API origin (no trailing slash). The app throws at startup if unset.
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Optional (UI)
# -----------------------------------------------------------------------------
# GitHub App slug for install links: https://github.com/apps/<slug>
# VITE_GITHUB_APP_SLUG=your-github-app-slug

# Enterprise pricing “Contact sales” mailto target
# VITE_SALES_EMAIL=sales@yourcompany.com

# -----------------------------------------------------------------------------
# Backend pairing
# -----------------------------------------------------------------------------
# Dodo checkout return/cancel URLs use CLIENT_URL from the API .env — set that to
# this frontend’s origin (e.g. http://localhost:5173 in Vite dev).
